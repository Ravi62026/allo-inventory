generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}

// ─── Core models ──────────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  category    String
  imageUrl    String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks Stock[]

  @@index([isActive])
  @@map("products")
}

model Warehouse {
  id       String  @id @default(cuid())
  name     String
  location String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks Stock[]

  @@index([isActive])
  @@map("warehouses")
}

model Stock {
  id            String @id @default(cuid())
  productId     String
  warehouseId   String
  totalUnits    Int    @default(0)
  reservedUnits Int    @default(0)

  // availableUnits = totalUnits - reservedUnits (computed in service layer)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id])
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  reservations Reservation[]

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("stocks")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]

  @@index([email])
  @@map("users")
}

model Reservation {
  id          String            @id @default(cuid())
  stockId     String
  userId      String?
  units       Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime
  confirmedAt DateTime?
  releasedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock Stock  @relation(fields: [stockId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@index([stockId])
  @@index([userId])
  @@index([status, expiresAt])
  @@map("reservations")
}
